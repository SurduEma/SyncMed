using Microsoft.AspNetCore.Mvc.RazorPages;
using SyncMed.Models;
using SyncMed.Services;

namespace SyncMed.Pages.Appointments;

public class SearchModel : PageModel
{
    private readonly IAppointmentService _service;

    public SearchModel(IAppointmentService service)
    {
        _service = service;
    }

    public IList<Appointment> Appointments { get; set; } = default!;

    public string? SearchDoctor { get; set; }
    public string? SearchPatient { get; set; }
    public DateOnly? SearchDate { get; set; }

    public bool HasSearched { get; set; }

    public async Task OnGetAsync(string? searchDoctor, string? searchPatient, DateOnly? searchDate)
    {
        SearchDoctor = searchDoctor;
        SearchPatient = searchPatient;
        SearchDate = searchDate;

        var allAppointments = await _service.GetAllAppointmentsAsync();

        // Filter by doctor name
        if (!string.IsNullOrWhiteSpace(searchDoctor))
        {
            var lowerDoctor = searchDoctor.ToLower();
            allAppointments = allAppointments
                .Where(a => a.Doctor.User.FirstName.ToLower().Contains(lowerDoctor)
                         || a.Doctor.User.LastName.ToLower().Contains(lowerDoctor))
                .ToList();
            HasSearched = true;
        }

        // Filter by patient name
        if (!string.IsNullOrWhiteSpace(searchPatient))
        {
            var lowerPatient = searchPatient.ToLower();
            allAppointments = allAppointments
                .Where(a => a.Patient.User.FirstName.ToLower().Contains(lowerPatient)
                         || a.Patient.User.LastName.ToLower().Contains(lowerPatient))
                .ToList();
            HasSearched = true;
        }

        // Filter by date
        if (searchDate.HasValue)
        {
            allAppointments = allAppointments
                .Where(a => a.AppointmentDate == searchDate.Value)
                .ToList();
            HasSearched = true;
        }

        Appointments = allAppointments
            .OrderByDescending(a => a.AppointmentDate)
            .ThenByDescending(a => a.AppointmentTime)
            .ToList();
    }
}
