@page
@model SyncMed.Pages.Appointments.IndexModel

@{
    ViewData["Title"] = "My Appointments";
}

<div class="container mt-4">
    <h1>My Appointments</h1>
    <hr />

    @if (!Model.Appointments.Any())
    {
        <div class="alert alert-info">
            <p>You have no appointments scheduled.</p>
            <a href="#" class="btn btn-primary mt-2">Request Appointment</a>
        </div>
    }
    else
    {
        <table class="table table-striped">
            <thead>
                <tr>
                    <th>Date</th>
                    <th>Time</th>
                    <th>Doctor</th>
                    <th>Specialty</th>
                    <th>Status</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var appointment in Model.Appointments)
                {
                    <tr>
                        <td>@appointment.AppointmentDate.ToString("dd MMM yyyy")</td>
                        <td>@appointment.AppointmentTime.ToString("HH:mm")</td>
                        <td>@appointment.Doctor.User.FirstName @appointment.Doctor.User.LastName</td>
                        <td>@appointment.Doctor.Specialty</td>
                        <td>
                            <span class="badge @(appointment.Status switch
                            {
                                "Confirmed" => "bg-success",
                                "Pending" => "bg-warning text-dark",
                                "Cancelled" => "bg-danger",
                                _ => "bg-secondary"
                            })">
                                @appointment.Status
                            </span>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }
</div>
