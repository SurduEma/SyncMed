<!DOCTYPE html>
<html lang="en">
<head>
    <title>@ViewData["Title"] - SyncMed</title>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/global.css" />
</head>
<body>
    <nav class="navbar">
        <div class="navbar-left">
            <a href="/">
                <img src="~/assets/SyncMedLogo.png" class="navbar-logo" alt="SyncMed Logo" />
            </a>
        </div>
        <div class="navbar-middle">
            <a asp-controller="Appointments" asp-action="Index">Appointments (MVC)</a>
        </div>
    </nav>

    <div class="container">
        @RenderBody()
    </div>
</body>
</html>
