<!DOCTYPE html>
<html lang="en">
<head>
    <title>@ViewData["Title"] - SyncMed</title>
    <meta charset="utf-8" />
    <meta name="author" content="Ema Surdu" />
    <meta name="robots" content="noindex, nofollow" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
          integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YcnS/1p0p/ejft0vhPq+jSAE0bJitqGMfmFk"
          crossorigin="anonymous" />
    <link rel="stylesheet" href="~/css/global.css" />
    @RenderSection("Styles", required: false)
</head>
<body>
    <nav class="navbar">
        <div class="navbar-left">
            <a asp-page="/Index">
                <img src="~/assets/SyncMedLogo.png" class="navbar-logo" alt="SyncMed Logo" />
            </a>
        </div>

        <div class="navbar-middle">
            <a asp-page="/Specialties/Index">Specialties</a>
            <a asp-page="/Index">Medical Team</a>
            <a asp-page="/Index">Patient Info</a>
            <a asp-page="/Index">Request Appointment</a>
            <a asp-page="/Index">Contact</a>
        </div>

        <div class="navbar-right">
            <a href="#" class="login-btn">Log In</a>
        </div>
    </nav>

    @RenderBody()
</body>
</html>
