<!DOCTYPE html>
<html lang="en">
<head>
    <title>@ViewData["Title"] - SyncMed</title>
    <meta charset="utf-8" />
    <meta name="author" content="noname" />
    <meta name="robots" content="noindex, nofollow" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    <link rel="stylesheet" href="~/css/global.css" />
    @RenderSection("Styles", required: false)
</head>
<body>
    <nav class="navbar navbar-expand-lg navbar-light bg-light shadow-sm">
        <div class="container-fluid px-4">
            <a asp-page="/Index" class="navbar-brand">
                <img src="~/assets/SyncMedLogo.png" alt="SyncMed Logo" style="height: 40px;" />
            </a>

            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                <span class="navbar-toggler-icon"></span>
            </button>

            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav ms-auto navbar-buttons">
                    <li class="nav-item"><a asp-page="/Index" class="nav-link">Home</a></li>
                    <li class="nav-item"><a asp-page="/Specialties/Index" class="nav-link">Specialties</a></li>
                    <li class="nav-item dropdown">
                        <a class="nav-link dropdown-toggle" href="#" id="appointmentDropdown" role="button" data-bs-toggle="dropdown">
                            Appointments
                        </a>
                        <ul class="dropdown-menu" aria-labelledby="appointmentDropdown">
                            <li><a asp-page="/Appointments/Index" class="dropdown-item">My Appointments</a></li>
                            <li><a asp-page="/Appointments/Search" class="dropdown-item">Search Appointments</a></li>
                        </ul>
                    </li>
                    <li class="nav-item dropdown">
                        <a class="nav-link dropdown-toggle" href="#" id="managementDropdown" role="button" data-bs-toggle="dropdown">
                            Management
                        </a>
                        <ul class="dropdown-menu" aria-labelledby="managementDropdown">
                            <li><a asp-page="/Doctors/Index" class="dropdown-item">Doctors</a></li>
                            <li><a asp-page="/Patients/Index" class="dropdown-item">Patients</a></li>
                        </ul>
                    </li>
                </ul>
                <a href="#" class="nav-link ms-3">Log In</a>
            </div>
        </div>
    </nav>

    @RenderBody()

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
