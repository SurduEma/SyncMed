@model Appointment

@{
    ViewData["Title"] = "Appointment Details";
}

<h1>Appointment Details</h1>
<hr />

<div>
    <dl class="row">
        <dt class="col-sm-3">Appointment Date</dt>
        <dd class="col-sm-9">@Model.AppointmentDate.ToString("dd MMM yyyy")</dd>

        <dt class="col-sm-3">Appointment Time</dt>
        <dd class="col-sm-9">@Model.AppointmentTime.ToString("HH:mm")</dd>

        <dt class="col-sm-3">Patient</dt>
        <dd class="col-sm-9">@Model.Patient.User.FirstName @Model.Patient.User.LastName</dd>

        <dt class="col-sm-3">Doctor</dt>
        <dd class="col-sm-9">@Model.Doctor.User.FirstName @Model.Doctor.User.LastName</dd>

        <dt class="col-sm-3">Specialty</dt>
        <dd class="col-sm-9">@Model.Doctor.Specialty</dd>

        <dt class="col-sm-3">Status</dt>
        <dd class="col-sm-9">@Model.Status</dd>
    </dl>
</div>

<div>
    <a asp-action="Index">Back to List</a>
</div>
