@model IEnumerable<Appointment>

@{
    ViewData["Title"] = "Appointments";
}

<h1>Appointments</h1>
<hr />

<table class="table table-striped">
    <thead>
        <tr>
            <th>Date</th>
            <th>Time</th>
            <th>Patient</th>
            <th>Doctor</th>
            <th>Specialty</th>
            <th>Status</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.AppointmentDate.ToString("dd MMM yyyy")</td>
                <td>@item.AppointmentTime.ToString("HH:mm")</td>
                <td>@item.Patient.User.FirstName @item.Patient.User.LastName</td>
                <td>@item.Doctor.User.FirstName @item.Doctor.User.LastName</td>
                <td>@item.Doctor.Specialty</td>
                <td>@item.Status</td>
                <td>
                    <a asp-action="Details" asp-route-id="@item.AppointmentId">Details</a>
                </td>
            </tr>
        }
    </tbody>
</table>
