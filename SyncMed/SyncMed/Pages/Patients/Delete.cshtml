@page "{id:int}"
@model SyncMed.Pages.Patients.DeleteModel

@{
    ViewData["Title"] = "Delete Patient";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow-sm border-0 border-danger">
                <div class="card-header bg-danger text-white">
                    <h4 class="mb-0">Delete Patient</h4>
                </div>
                <div class="card-body p-4">
                    <div class="alert alert-warning mb-4">
                        <i class="fas fa-exclamation-triangle"></i>
                        <strong>Warning!</strong> You are about to delete this patient permanently.
                    </div>

                    <div class="mb-4 p-3 bg-light rounded">
                        <p class="mb-2">
                            <strong>@Model.Patient.User.FirstName @Model.Patient.User.LastName</strong>
                        </p>
                        <p class="mb-2">
                            <small class="text-muted">@Model.Patient.User.Email</small>
                        </p>
                        <p class="mb-0">
                            <small class="text-muted">DOB: @Model.Patient.DateOfBirth.ToString("dd MMM yyyy")</small>
                        </p>
                    </div>

                    <p class="text-danger small mb-4">
                        This action cannot be undone. All associated appointments will be affected.
                    </p>

                    <form method="post">
                        <input type="hidden" asp-for="Patient.PatientId" />
                        <div class="d-flex gap-2">
                            <button type="submit" class="btn btn-danger">
                                <i class="fas fa-trash"></i> Delete Patient
                            </button>
                            <a asp-page="Index" class="btn btn-secondary">
                                <i class="fas fa-arrow-left"></i> Cancel
                            </a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
