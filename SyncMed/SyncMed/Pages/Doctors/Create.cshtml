@page
@model SyncMed.Pages.Doctors.CreateModel

@{
    ViewData["Title"] = "Add New Doctor";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card shadow-sm border-0">
                <div class="card-header bg-primary text-white">
                    <h4 class="mb-0">Add New Doctor</h4>
                </div>
                <div class="card-body p-4">
                    <form method="post">
                        <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

                        <div class="mb-3">
                            <label asp-for="Doctor.User.FirstName" class="form-label">First Name</label>
                            <input asp-for="Doctor.User.FirstName" class="form-control" placeholder="First name" />
                            <span asp-validation-for="Doctor.User.FirstName" class="text-danger small"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Doctor.User.LastName" class="form-label">Last Name</label>
                            <input asp-for="Doctor.User.LastName" class="form-control" placeholder="Last name" />
                            <span asp-validation-for="Doctor.User.LastName" class="text-danger small"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Doctor.User.Email" class="form-label">Email</label>
                            <input asp-for="Doctor.User.Email" class="form-control" type="email" placeholder="doctor@syncmed.com" />
                            <span asp-validation-for="Doctor.User.Email" class="text-danger small"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Doctor.Specialty" class="form-label">Specialty</label>
                            <input asp-for="Doctor.Specialty" class="form-control" placeholder="e.g., Cardiology" />
                            <span asp-validation-for="Doctor.Specialty" class="text-danger small"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Doctor.DoctorLicenseId" class="form-label">License ID</label>
                            <input asp-for="Doctor.DoctorLicenseId" class="form-control" placeholder="e.g., LIC-001" />
                            <span asp-validation-for="Doctor.DoctorLicenseId" class="text-danger small"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Doctor.WorkingHours" class="form-label">Working Hours (optional)</label>
                            <input asp-for="Doctor.WorkingHours" class="form-control" placeholder="e.g., Mon-Fri 09:00-17:00" />
                            <span asp-validation-for="Doctor.WorkingHours" class="text-danger small"></span>
                        </div>

                        <div class="d-flex gap-2 mt-4">
                            <button type="submit" class="btn btn-primary">
                                <i class="fas fa-save"></i> Add Doctor
                            </button>
                            <a asp-page="Index" class="btn btn-secondary">
                                <i class="fas fa-arrow-left"></i> Cancel
                            </a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
