@page
@model SyncMed.Pages.Appointments.SearchModel

@{
    ViewData["Title"] = "Search Appointments";
}

<div class="container mt-5">
    <div class="row mb-4">
        <div class="col-md-12">
            <h1>Search Appointments</h1>
            <p class="text-muted">Find and filter appointments</p>
        </div>
    </div>

    <div class="card shadow-sm border-0 mb-4">
        <div class="card-header bg-primary text-white">
            <h5 class="mb-0">Filter Appointments</h5>
        </div>
        <div class="card-body p-4">
            <form method="get">
                <div class="row g-3">
                    <div class="col-md-3">
                        <label asp-for="SearchDoctor" class="form-label">Doctor Name</label>
                        <input asp-for="SearchDoctor" class="form-control" placeholder="e.g., Alice Smith" />
                    </div>

                    <div class="col-md-3">
                        <label asp-for="SearchPatient" class="form-label">Patient Name</label>
                        <input asp-for="SearchPatient" class="form-control" placeholder="e.g., John Doe" />
                    </div>

                    <div class="col-md-3">
                        <label asp-for="SearchDate" class="form-label">Date</label>
                        <input asp-for="SearchDate" class="form-control" type="date" />
                    </div>

                    <div class="col-md-3 d-flex align-items-end">
                        <button type="submit" class="btn btn-primary w-100">
                            <i class="fas fa-search"></i> Search
                        </button>
                    </div>
                </div>
            </form>
        </div>
    </div>

    @if (Model.Appointments.Any())
    {
        <div class="card shadow-sm border-0">
            <div class="card-header bg-light">
                <h5 class="mb-0">Results (@Model.Appointments.Count())</h5>
            </div>
            <div class="table-responsive">
                <table class="table table-hover mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>Date</th>
                            <th>Time</th>
                            <th>Patient</th>
                            <th>Doctor</th>
                            <th>Specialty</th>
                            <th>Status</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var appointment in Model.Appointments)
                        {
                            <tr>
                                <td>@appointment.AppointmentDate.ToString("dd MMM yyyy")</td>
                                <td>@appointment.AppointmentTime.ToString("HH:mm") – @appointment.AppointmentTime.Add(TimeSpan.FromMinutes(30)).ToString("HH:mm")</td>
                                <td>@appointment.Patient.User.FirstName @appointment.Patient.User.LastName</td>
                                <td>Dr. @appointment.Doctor.User.FirstName @appointment.Doctor.User.LastName</td>
                                <td>@appointment.Doctor.Specialty</td>
                                <td>
                                    <span class="badge @(appointment.Status switch
                                    {
                                        "Confirmed" => "bg-success",
                                        "Pending" => "bg-warning text-dark",
                                        "Cancelled" => "bg-danger",
                                        _ => "bg-secondary"
                                    })">
                                        @appointment.Status
                                    </span>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }
    else if (Model.HasSearched)
    {
        <div class="alert alert-info">
            <p class="mb-0">No appointments found matching your search criteria.</p>
        </div>
    }
    else
    {
        <div class="alert alert-info">
            <p class="mb-0">Use the filter form above to search for appointments.</p>
        </div>
    }
</div>
