@page "{id:int}"
@model SyncMed.Pages.Appointments.EditModel
@{
    ViewData["Title"] = "Edit Appointment";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card shadow-sm border-0">
                <div class="card-header bg-primary text-white">
                    <h4 class="mb-0">Edit Appointment</h4>
                </div>
                <div class="card-body p-4">
                    <form method="post">
                        <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

                        <input type="hidden" asp-for="Appointment.AppointmentId" />

                        <div class="mb-3">
                            <label asp-for="Appointment.PatientId" class="form-label">Patient</label>
                            <select asp-for="Appointment.PatientId" asp-items="Model.PatientList" class="form-select">
                                <option value="">-- Select Patient --</option>
                            </select>
                            <span asp-validation-for="Appointment.PatientId" class="text-danger small"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Appointment.DoctorId" class="form-label">Doctor</label>
                            <select asp-for="Appointment.DoctorId" asp-items="Model.DoctorList" class="form-select">
                                <option value="">-- Select Doctor --</option>
                            </select>
                            <span asp-validation-for="Appointment.DoctorId" class="text-danger small"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Appointment.AppointmentDate" class="form-label">Appointment Date</label>
                            <input type="date" asp-for="Appointment.AppointmentDate" class="form-control" />
                            <span asp-validation-for="Appointment.AppointmentDate" class="text-danger small"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Appointment.AppointmentTime" class="form-label">Appointment Time</label>
                            <input type="time" asp-for="Appointment.AppointmentTime" class="form-control" />
                            <span asp-validation-for="Appointment.AppointmentTime" class="text-danger small"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Appointment.Status" class="form-label">Status</label>
                            <select asp-for="Appointment.Status" asp-items="Model.StatusList" class="form-select">
                                <option value="">-- Select Status --</option>
                            </select>
                            <span asp-validation-for="Appointment.Status" class="text-danger small"></span>
                        </div>

                        <div class="d-flex gap-2 mt-4">
                            <button type="submit" class="btn btn-primary">
                                <i class="fas fa-save"></i> Save Changes
                            </button>
                            <a asp-page="Index" class="btn btn-secondary">
                                <i class="fas fa-arrow-left"></i> Cancel
                            </a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
