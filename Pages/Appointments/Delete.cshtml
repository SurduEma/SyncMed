@page "{id:int}"
@model SyncMed.Pages.Appointments.DeleteModel
@{
    ViewData["Title"] = "Cancel Appointment";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow-sm border-0 border-danger">
                <div class="card-header bg-danger text-white">
                    <h4 class="mb-0">Cancel Appointment</h4>
                </div>
                <div class="card-body p-4">
                    <div class="alert alert-warning mb-4">
                        <i class="fas fa-exclamation-triangle"></i>
                        <strong>Warning!</strong> You are about to cancel this appointment permanently.
                    </div>

                    <div class="mb-4 p-3 bg-light rounded">
                        <p class="mb-2">
                            <strong>Patient:</strong> @Model.Appointment.Patient.User.FirstName @Model.Appointment.Patient.User.LastName
                        </p>
                        <p class="mb-2">
                            <strong>Doctor:</strong> Dr. @Model.Appointment.Doctor.User.FirstName @Model.Appointment.Doctor.User.LastName
                        </p>
                        <p class="mb-2">
                            <strong>Specialty:</strong> @Model.Appointment.Doctor.Specialty
                        </p>
                        <p class="mb-2">
                            <strong>Date:</strong> @Model.Appointment.AppointmentDate.ToString("dd MMM yyyy")
                        </p>
                        <p class="mb-0">
                            <strong>Time:</strong> @Model.Appointment.AppointmentTime.ToString("HH:mm")
                        </p>
                    </div>

                    <p class="text-muted small mb-4">
                        <strong>Current Status:</strong> <span class="badge @(Model.Appointment.Status switch { "Confirmed" => "bg-success", "Pending" => "bg-warning text-dark", "Cancelled" => "bg-danger", _ => "bg-secondary" })">@Model.Appointment.Status</span>
                    </p>

                    <form method="post">
                        <input type="hidden" asp-for="Appointment.AppointmentId" />
                        <div class="d-flex gap-2">
                            <button type="submit" class="btn btn-danger">
                                <i class="fas fa-trash"></i> Cancel Appointment
                            </button>
                            <a asp-page="Index" class="btn btn-secondary">
                                <i class="fas fa-arrow-left"></i> Go Back
                            </a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
