@page "{appointmentId:int}"
@model SyncMed.Pages.Consultations.NotesModel

@{
    ViewData["Title"] = "Consultation Notes";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-lg-8">
            <div class="card shadow-sm border-0">
                <div class="card-header bg-primary text-white">
                    <h1 class="h4 mb-0">Consultation Notes</h1>
                </div>
                <div class="card-body p-4">
                    <div class="mb-4 text-muted">
                        @Model.Appointment.Patient.User.FirstName @Model.Appointment.Patient.User.LastName -
                        @Model.Appointment.AppointmentDate.ToString("dd MMM yyyy") @Model.Appointment.AppointmentTime.ToString("HH:mm")
                    </div>

                    @if (!string.IsNullOrWhiteSpace(Model.Vitals))
                    {
                        <div class="alert alert-info">
                            <strong>Vitals:</strong> @Model.Vitals
                        </div>
                    }

                    <form method="post">
                        <input type="hidden" asp-for="AppointmentId" />
                        <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

                        <div class="mb-3">
                            <label asp-for="Symptoms" class="form-label">Symptoms</label>
                            <textarea asp-for="Symptoms" class="form-control" rows="5"></textarea>
                            <span asp-validation-for="Symptoms" class="text-danger small"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Diagnosis" class="form-label">Diagnosis</label>
                            <textarea asp-for="Diagnosis" class="form-control" rows="5"></textarea>
                            <span asp-validation-for="Diagnosis" class="text-danger small"></span>
                        </div>

                        <div class="d-flex gap-2">
                            <button type="submit" class="btn btn-primary">Save</button>
                            <a asp-page="/Patients/Details" asp-route-id="@Model.Appointment.PatientId" class="btn btn-secondary">Cancel</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
