@page
@model SyncMed.Pages.Services.IndexModel

@{
    ViewData["Title"] = "Services";
}

<div class="container mt-5">
    <div class="row mb-4">
        <div class="col-md-8">
            <h1>Our Services</h1>
            <p class="text-muted">Manage available medical services and their pricing</p>
        </div>
        @if (User.IsInRole(AppRoles.Admin))
        {
            <div class="col-md-4 text-end">
                <a asp-page="Create" class="btn btn-primary btn-lg">
                    <i class="fas fa-plus"></i> Add New Service
                </a>
            </div>
        }
    </div>

    <form method="get" class="mb-4">
        <div class="row">
            <div class="col-md-4">
                <label asp-for="Specialty" class="form-label">Filter by Specialty:</label>
                <select asp-for="Specialty" asp-items="Model.Specialties" class="form-select" onchange="this.form.submit()">
                </select>
            </div>
        </div>
    </form>

    @if (!Model.Services.Any())
    {
        <div class="alert alert-info">
            <p class="mb-0">
                No services found for this specialty.
                @if (User.IsInRole(AppRoles.Admin))
                {
                    <a asp-page="Create">Add the first one</a>
                }
            </p>
        </div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table table-striped table-hover align-middle">
                <thead class="table-dark">
                    <tr>
                        <th>Name</th>
                        <th>Description</th>
                        <th>Price</th>
                        @if (User.IsInRole(AppRoles.Admin))
                        {
                            <th class="text-end">Actions</th>
                        }
                    </tr>
                </thead>
                <tbody>
                    @foreach (var service in Model.Services)
                    {
                        <tr>
                            <td class="fw-bold">@service.Name</td>
                            <td>@service.Description</td>
                            <td>@service.Price.ToString("C")</td>
                            @if (User.IsInRole(AppRoles.Admin))
                            {
                                <td class="text-end">
                                    <a asp-page="Edit" asp-route-id="@service.MedicalServiceId" class="btn btn-sm btn-warning">
                                        <i class="fas fa-edit"></i> Edit
                                    </a>
                                    <a asp-page="Delete" asp-route-id="@service.MedicalServiceId" class="btn btn-sm btn-danger ms-1">
                                        <i class="fas fa-trash"></i> Delete
                                    </a>
                                </td>
                            }
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>
