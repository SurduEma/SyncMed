@page "{id:int}"
@model SyncMed.Pages.Services.EditModel

@{
    ViewData["Title"] = "Edit Service";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card shadow-sm border-0">
                <div class="card-header bg-warning text-dark">
                    <h4 class="mb-0">Edit Service</h4>
                </div>
                <div class="card-body p-4">
                    <form method="post">
                        <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

                        <input type="hidden" asp-for="MedicalService.MedicalServiceId" />

                        <div class="mb-3">
                            <label asp-for="MedicalService.Specialty" class="form-label">Specialty</label>
                            <select asp-for="MedicalService.Specialty" asp-items="Model.Specialties" class="form-select">
                                <option value="">-- Select Specialty --</option>
                            </select>
                            <span asp-validation-for="MedicalService.Specialty" class="text-danger small"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="MedicalService.Name" class="form-label">Service Name</label>
                            <input asp-for="MedicalService.Name" class="form-control" />
                            <span asp-validation-for="MedicalService.Name" class="text-danger small"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="MedicalService.Description" class="form-label">Description (Optional)</label>
                            <textarea asp-for="MedicalService.Description" class="form-control" rows="3"></textarea>
                            <span asp-validation-for="MedicalService.Description" class="text-danger small"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="MedicalService.Price" class="form-label">Price</label>
                            <div class="input-group">
                                <span class="input-group-text">$</span>
                                <input asp-for="MedicalService.Price" class="form-control" type="number" step="0.01" />
                            </div>
                            <span asp-validation-for="MedicalService.Price" class="text-danger small"></span>
                        </div>

                        <div class="d-flex gap-2 mt-4">
                            <button type="submit" class="btn btn-warning">
                                <i class="fas fa-save"></i> Save Changes
                            </button>
                            <a asp-page="Index" class="btn btn-secondary">
                                <i class="fas fa-arrow-left"></i> Cancel
                            </a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
