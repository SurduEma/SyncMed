@page "{id:int}"
@model SyncMed.Pages.Services.DeleteModel

@{
    ViewData["Title"] = "Delete Service";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow-sm border-0 border-danger">
                <div class="card-header bg-danger text-white">
                    <h4 class="mb-0"><i class="fas fa-exclamation-triangle"></i> Delete Service</h4>
                </div>
                <div class="card-body p-4 text-center">
                    <h5 class="mb-3">Are you sure you want to delete this service?</h5>
                    <p class="text-muted mb-4">This action cannot be undone.</p>

                    <div class="card bg-light mb-4 text-start">
                        <div class="card-body">
                            <h5 class="card-title">@Model.MedicalService.Name</h5>
                            <p class="card-text">
                                <strong>Specialty:</strong> @Model.MedicalService.Specialty<br />
                                <strong>Price:</strong> @Model.MedicalService.Price.ToString("C")
                            </p>
                        </div>
                    </div>

                    <form method="post">
                        <input type="hidden" asp-for="MedicalService.MedicalServiceId" />
                        <div class="d-flex justify-content-center gap-3">
                            <button type="submit" class="btn btn-danger px-4">
                                <i class="fas fa-trash"></i> Yes, Delete
                            </button>
                            <a asp-page="Index" class="btn btn-secondary px-4">
                                <i class="fas fa-times"></i> Cancel
                            </a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
