@page
@model SyncMed.Pages.Specialties.IndexModel

@{
    ViewData["Title"] = "Medical Specialties";
}

@section Styles {
    <link rel="stylesheet" href="~/css/specialties.css" />
}

<div class="specialties-page">
    <div class="specialties-header">
        <h1>Medical Specialties</h1>
        <p>Explore our comprehensive range of medical specialties and expert healthcare services</p>
    </div>

    @if (!Model.SpecialtiesInfo.Any())
    {
        <div class="container mt-5">
            <div class="alert alert-info">
                <p class="mb-0">No specialties available yet.</p>
            </div>
        </div>
    }
    else
    {
        <div class="specialties-grid">
            @foreach (var specialty in Model.SpecialtiesInfo)
            {
                <div class="specialty-card">
                    <div class="specialty-image">
                        <img src="@specialty.ImagePath" alt="@specialty.Name" />
                    </div>
                    <div class="specialty-content">
                        <h2>@specialty.Name</h2>
                        <p>@specialty.Description</p>
                        <a href="/Doctors?specialty=@Uri.EscapeDataString(specialty.Name)" class="btn btn-primary mt-3">
                            View Doctors <i class="fas fa-arrow-right"></i>
                        </a>
                    </div>
                </div>
            }
        </div>
    }
</div>
