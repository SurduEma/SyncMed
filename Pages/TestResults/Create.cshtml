@page
@model SyncMed.Pages.TestResults.CreateModel

@{
    ViewData["Title"] = "Upload Test Result";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-lg-8">
            <div class="card shadow-sm border-0">
                <div class="card-header bg-primary text-white">
                    <h1 class="h4 mb-0">Upload Test Result</h1>
                </div>
                <div class="card-body p-4">
                    <form method="post">
                        <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

                        <div class="mb-3">
                            <label asp-for="PatientId" class="form-label">Patient</label>
                            <select asp-for="PatientId" asp-items="Model.PatientList" class="form-select">
                                <option value="">-- Select Patient --</option>
                            </select>
                            <span asp-validation-for="PatientId" class="text-danger small"></span>
                        </div>

                        @if (!User.IsInRole(AppRoles.Doctor))
                        {
                            <div class="mb-3">
                                <label asp-for="DoctorId" class="form-label">Uploaded By</label>
                                <select asp-for="DoctorId" asp-items="Model.DoctorList" class="form-select">
                                    <option value="">-- Select Doctor --</option>
                                </select>
                                <span asp-validation-for="DoctorId" class="text-danger small"></span>
                            </div>
                        }
                        else
                        {
                            <input type="hidden" asp-for="DoctorId" />
                        }

                        <div class="mb-3">
                            <label asp-for="TestName" class="form-label">Test Name</label>
                            <input asp-for="TestName" class="form-control" />
                            <span asp-validation-for="TestName" class="text-danger small"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="DocumentUrl" class="form-label">Document URL</label>
                            <input asp-for="DocumentUrl" class="form-control" />
                            <span asp-validation-for="DocumentUrl" class="text-danger small"></span>
                        </div>

                        <div class="d-flex gap-2">
                            <button type="submit" class="btn btn-primary">Upload</button>
                            <a asp-page="/Patients/Details" asp-route-id="@Model.PatientId" class="btn btn-secondary">Cancel</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
